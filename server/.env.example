PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret

# Supabase Postgres connection strings. For local smoke testing,
# DATABASE_URL can temporarily match DIRECT_URL. For Render production,
# prefer Supabase's pooled connection string for DATABASE_URL.
DATABASE_URL=postgresql://postgres.project-ref:password@region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# Optional: explanation generation only. Rankings always come from rules.
# AI_PROVIDER can be auto, openai, anthropic, or qwen.
AI_PROVIDER=qwen

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Alibaba Cloud Model Studio / DashScope OpenAI-compatible API.
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
